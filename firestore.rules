rules_version = '2';

// Holobots Firestore Security Rules
// -----------------------------------------------------------------------------
// SECURITY MODEL & KNOWN LIMITATION
//
// The mobile client currently writes economy fields (holosTokens, syncPoints,
// gachaTickets, holobots, leaderboardScore, battle_cards, inventory, ...)
// directly to /users/{uid}. These rules therefore CANNOT make those fields
// fully immutable without breaking the shipping app. Instead they:
//   * require authentication for every read/write (was previously ungoverned),
//   * scope every document to its owner (no cross-account reads/writes),
//   * block privilege escalation (isDevAccount, uid spoofing),
//   * reject malformed / negative / absurdly large economy values as
//     defense-in-depth against trivial "set balance = 1e9" attacks,
//   * restrict PvP room/pool writes to participants.
//
// FULL economy integrity still REQUIRES moving value-granting logic
// (gacha, battle payouts, fitness conversion, quests, purchases, minting,
// mission claims, leaderboard scoring, PvP resolution) into Cloud Functions
// that recompute from server-trusted state. See SECURITY_AUDIT.md (C1-C5, H1-H7).
// Once those writes move server-side, tighten the economy fields below to
// `allow write: if false` for the client and delete the sanity-cap helpers.
// -----------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers -----------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // A defensive upper bound. Far above any legitimate balance, but blocks
    // the "set my currency to 1e9" class of tampering. Not a substitute for
    // server-authoritative economy (see header).
    function sane(n) {
      return n is number && n >= 0 && n <= 100000000;
    }

    function saneOptional(data, field) {
      return !(field in data) || sane(data[field]);
    }

    // Fields the client must never be able to set/raise itself.
    function noPrivilegeEscalation(data) {
      return !('isDevAccount' in data) || data.isDevAccount == false;
    }

    // Epoch-millisecond timestamps written by client fallbacks (sane() caps
    // at 1e8, far below Date.now()).
    function saneEpochMsOptional(data, field) {
      return !(field in data)
        || (data[field] is number && data[field] >= 0 && data[field] < 100000000000000);
    }

    // Referral/Genesis fields are awarded only by the growth callables and
    // the fitness-sync qualification hook (Admin SDK bypasses rules). The
    // client may never introduce or change them: on update the post-merge
    // value must equal what is already stored (same unchanged-or-absent
    // shape as the isDevAccount flip-guard below).
    function serverOnlyFieldFrozen(data, existing, field) {
      return !(field in data) || (field in existing && data[field] == existing[field]);
    }

    function referralFieldsFrozen(data, existing) {
      return serverOnlyFieldFrozen(data, existing, 'referredBy')
        && serverOnlyFieldFrozen(data, existing, 'referrals')
        && serverOnlyFieldFrozen(data, existing, 'referralQualified')
        && serverOnlyFieldFrozen(data, existing, 'genesisSquadClaimed')
        && serverOnlyFieldFrozen(data, existing, 'genesisBadge');
    }

    function referralFieldsAbsent(data) {
      return !('referredBy' in data)
        && !('referrals' in data)
        && !('referralQualified' in data)
        && !('genesisSquadClaimed' in data)
        && !('genesisBadge' in data);
    }

    // referralCode IS client-writable (owners lazily publish their own code
    // so applyReferralCode can query it). Spoofing someone else's code is
    // inert — the callable re-derives the code from the matched doc's uid —
    // so a length cap is the only constraint worth enforcing here.
    function referralCodeSane(data) {
      return !('referralCode' in data)
        || (data.referralCode is string && data.referralCode.size() <= 12);
    }

    // ---- economy freeze (2026-07-12) ----------------------------------------
    // Currency, items, loot, and fitness-derived stats are paid ONLY by the
    // callables (Admin SDK bypasses rules). The mobile client fallbacks were
    // removed the same day; the holobots-fun web app's client-side economy
    // writes break by design until it migrates (owner decision).
    // Still client-writable on purpose: dailyEnergy + energy timestamps
    // (regen/quest/training starts), holobots (attribute-point spends),
    // battle_cards + arena_deck_template_ids + starter_deck_claimed (deck
    // building & signup starter grant), equippedParts, inventory,
    // rewardSystem (mission/quest state), leaderboardScore (recomputed by
    // legit holobots writes), asyncBattleTickets, prestigeCount.
    function economyFrozenOnUpdate(data, existing) {
      return serverOnlyFieldFrozen(data, existing, 'holosTokens')
        && serverOnlyFieldFrozen(data, existing, 'syncPoints')
        && serverOnlyFieldFrozen(data, existing, 'lifetimeSyncPoints')
        && serverOnlyFieldFrozen(data, existing, 'seasonSyncPoints')
        && serverOnlyFieldFrozen(data, existing, 'syncRank')
        && serverOnlyFieldFrozen(data, existing, 'gachaTickets')
        && serverOnlyFieldFrozen(data, existing, 'arenaPassses')
        && serverOnlyFieldFrozen(data, existing, 'expBoosters')
        && serverOnlyFieldFrozen(data, existing, 'energyRefills')
        && serverOnlyFieldFrozen(data, existing, 'rankSkips')
        && serverOnlyFieldFrozen(data, existing, 'wins')
        && serverOnlyFieldFrozen(data, existing, 'losses')
        && serverOnlyFieldFrozen(data, existing, 'blueprints')
        && serverOnlyFieldFrozen(data, existing, 'wildcardBlueprints')
        && serverOnlyFieldFrozen(data, existing, 'lastWildcardPackAt')
        && serverOnlyFieldFrozen(data, existing, 'parts')
        && serverOnlyFieldFrozen(data, existing, 'packHistory')
        && serverOnlyFieldFrozen(data, existing, 'todaySteps');
    }

    // On CREATE the frozen fields may only carry their signup defaults.
    function frozenZeroOnCreate(data, field) {
      return !(field in data) || data[field] == 0;
    }
    function frozenEmptyOnCreate(data, field) {
      return !(field in data) || data[field].size() == 0;
    }
    function economyFrozenOnCreate(data) {
      return frozenZeroOnCreate(data, 'holosTokens')
        && frozenZeroOnCreate(data, 'syncPoints')
        && frozenZeroOnCreate(data, 'lifetimeSyncPoints')
        && frozenZeroOnCreate(data, 'seasonSyncPoints')
        && (!('syncRank' in data) || data.syncRank == 'Rookie')
        && frozenZeroOnCreate(data, 'gachaTickets')
        && frozenZeroOnCreate(data, 'arenaPassses')
        && frozenZeroOnCreate(data, 'expBoosters')
        && frozenZeroOnCreate(data, 'energyRefills')
        && frozenZeroOnCreate(data, 'rankSkips')
        && frozenZeroOnCreate(data, 'wins')
        && frozenZeroOnCreate(data, 'losses')
        && frozenEmptyOnCreate(data, 'blueprints')
        && frozenZeroOnCreate(data, 'wildcardBlueprints')
        && !('lastWildcardPackAt' in data)
        && frozenEmptyOnCreate(data, 'parts')
        && frozenEmptyOnCreate(data, 'packHistory')
        && frozenZeroOnCreate(data, 'todaySteps');
    }

    // Numeric economy fields we sanity-check on write.
    function economyFieldsSane(data) {
      return saneOptional(data, 'holosTokens')
        && saneOptional(data, 'syncPoints')
        && saneOptional(data, 'lifetimeSyncPoints')
        && saneOptional(data, 'seasonSyncPoints')
        && saneOptional(data, 'gachaTickets')
        && saneOptional(data, 'arenaPassses')
        && saneOptional(data, 'expBoosters')
        && saneOptional(data, 'energyRefills')
        && saneOptional(data, 'rankSkips')
        && saneOptional(data, 'asyncBattleTickets')
        && saneOptional(data, 'dailyEnergy')
        && saneOptional(data, 'maxDailyEnergy')
        && saneOptional(data, 'stepEnergyGrantedToday')
        && saneOptional(data, 'leaderboardScore')
        && saneOptional(data, 'prestigeCount')
        && saneOptional(data, 'wins')
        && saneOptional(data, 'losses')
        && saneOptional(data, 'todaySteps')
        && saneOptional(data, 'wildcardBlueprints')
        && saneEpochMsOptional(data, 'lastWildcardPackAt');
    }

    // ---- users -------------------------------------------------------------
    // Read: any signed-in user (leaderboard reads the top-N of this collection).
    //   NOTE: this exposes the full user document to every authenticated user,
    //   which is a privacy concern (see SECURITY_AUDIT.md, data-privacy). The
    //   durable fix is a dedicated `/leaderboard` projection with only public
    //   fields; until then reads are gated on auth (previously ungoverned).
    // Write: owner only, with anti-escalation + sanity validation.
    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && noPrivilegeEscalation(request.resource.data)
        && economyFieldsSane(request.resource.data)
        && economyFrozenOnCreate(request.resource.data)
        && referralFieldsAbsent(request.resource.data)
        && referralCodeSane(request.resource.data);

      // NOTE: noPrivilegeEscalation applies to CREATE only. On update,
      // request.resource.data is the whole post-merge document, so a legacy
      // account that already has isDevAccount: true would fail it on EVERY
      // write (bricking all economy actions for that account). The clause
      // below enforces the actual invariant: the client may keep the
      // existing value or set false, but can never flip false -> true.
      allow update: if isOwner(uid)
        && economyFieldsSane(request.resource.data)
        && economyFrozenOnUpdate(request.resource.data, resource.data)
        && referralFieldsFrozen(request.resource.data, resource.data)
        && referralCodeSane(request.resource.data)
        && (!('isDevAccount' in request.resource.data)
            || request.resource.data.isDevAccount == resource.data.get('isDevAccount', false)
            || request.resource.data.isDevAccount == false);

      allow delete: if isOwner(uid);

      // Owner-scoped subcollections (fitness_daily, etc.).
      //
      // IMPORTANT: in rules_version '2', a bare `match /{document=**}` here
      // ALSO matches /users/{uid} itself (recursive wildcards match zero or
      // more segments), which would OR a blanket owner-allow over the
      // validated create/update rules above and silently disable
      // economyFieldsSane + noPrivilegeEscalation. The extra {subcollection}
      // segment forces this block to apply only to documents strictly below
      // the user document. Regression coverage: rules-tests/tests/
      // auth-privilege.test.ts and mobile-writes.test.ts.
      match /{subcollection}/{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // ---- PvP matchmaking pool ---------------------------------------------
    // Entries are self-describing via their userId field: the mobile client
    // keys docs by uid (one entry per player), the web client still writes
    // auto-ID docs, so ownership checks the field rather than the path
    // segment. Any signed-in searcher may CLAIM an active entry — flip
    // isActive to false and stamp the shared roomId, touching exactly those
    // two fields — which the transactional pairing in
    // mobile/src/lib/pvpMatchmaking.ts commits atomically with the room
    // creation so two simultaneous searchers can never both create rooms.
    match /battle_pool_entries/{entryId} {
      function ownsEntry() {
        return isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
      }
      function isClaim() {
        return isSignedIn()
          && resource.data.get('isActive', false) == true
          && request.resource.data.get('isActive', true) == false
          && request.resource.data.get('roomId', '') != ''
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isActive', 'roomId']);
      }
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if ownsEntry() || isClaim();
      allow delete: if ownsEntry();
    }

    // ---- PvP battle rooms --------------------------------------------------
    // Participant uids live at players.p1.uid / players.p2.uid — the only
    // shape either client (mobile or holobots-fun web) has ever written. The
    // previous rule checked top-level hostId/guestId/p1/p2 fields that never
    // existed, so every real participant update (heartbeat, stamina regen,
    // playCard, join) was denied. Writes are limited to the two recorded
    // participants, plus a joiner filling the empty p2 slot of a waiting
    // room. This still does NOT validate individual moves (a participant can
    // write an illegal board state) — authoritative move validation requires
    // a Cloud Function (SECURITY_AUDIT.md C4).
    match /battle_rooms/{roomId} {
      function isParticipant(data) {
        return isSignedIn()
          && (request.auth.uid == data.get(['players', 'p1', 'uid'], '')
              || request.auth.uid == data.get(['players', 'p2', 'uid'], ''));
      }
      function isJoiningOpenSlot() {
        return isSignedIn()
          && resource.data.get('status', '') == 'waiting'
          && resource.data.get(['players', 'p2', 'uid'], '') == ''
          && request.resource.data.get(['players', 'p2', 'uid'], '') == request.auth.uid;
      }
      allow read: if isSignedIn();
      allow create: if isParticipant(request.resource.data);
      allow update: if isParticipant(resource.data) || isJoiningOpenSlot();
      allow delete: if isParticipant(resource.data);
    }

    // ---- default deny ------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
